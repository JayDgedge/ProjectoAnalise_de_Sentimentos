# 11. PALAVRAS MAIS DISCRIMINATIVAS POR CLASSE
# REGRESSÃO LOGÍSTICA + TF-IDF
# ============================================================

X_train, X_test, y_train, y_test = train_test_split(
    X_tfidf,
    y,
    test_size=0.2,
    random_state=42,
    stratify=y
)

modelo_interpretavel = LogisticRegression(max_iter=1000)
modelo_interpretavel.fit(X_train, y_train)

palavras = tfidf_vectorizer.get_feature_names_out()
classes = modelo_interpretavel.classes_

top_n = 15
linhas = []

for i, classe in enumerate(classes):
    coeficientes = modelo_interpretavel.coef_[i]
    indices_top = np.argsort(coeficientes)[-top_n:][::-1]

    print("\n=================================================")
    print(f"PALAVRAS MAIS DISCRIMINATIVAS PARA: {classe}")
    print("=================================================")

    for indice in indices_top:
        palavra = palavras[indice]
        peso = coeficientes[indice]

        print(f"{palavra} -> peso: {peso:.4f}")

        linhas.append({
            "classe": classe,
            "palavra": palavra,
            "peso": peso
        })

df_palavras = pd.DataFrame(linhas)

df_palavras.to_csv(
    "palavras_discriminativas_por_classe.csv",
    index=False,
    encoding="utf-8-sig"
)

print("\nPalavras discriminativas guardadas como:")
print("palavras_discriminativas_por_classe.csv")


