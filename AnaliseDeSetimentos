# ============================================================
# 4. FUNÇÕES DE PRÉ-PROCESSAMENTO
# ============================================================

def remover_acentos(texto):
    texto = unicodedata.normalize("NFKD", str(texto))
    texto = texto.encode("ASCII", "ignore").decode("utf-8")
    return texto


def normalizar_texto(texto):
    texto = str(texto).lower()
    texto = remover_acentos(texto)

    texto = re.sub(r"http\S+|www\S+", " ", texto)
    texto = re.sub(r"@\w+", " ", texto)
    texto = re.sub(r"#", " ", texto)

    texto = re.sub(r"[^a-zA-Z\s]", " ", texto)
    texto = re.sub(r"\s+", " ", texto).strip()

    return texto


def tokenizar(texto):
    return texto.split()


def remover_stopwords(tokens):
    return [
        palavra for palavra in tokens
        if palavra not in stopwords_pt and len(palavra) > 2
    ]


def stemming_simples(palavra):
    sufixos = [
        "mente", "coes", "cao", "sao",
        "idades", "idade",
        "amentos", "amento",
        "imentos", "imento",
        "adoras", "adora", "adores", "ador",
        "antes", "ante",
        "aveis", "avel",
        "iveis", "ivel",
        "adas", "ados", "ada", "ado",
        "idas", "idos", "ida", "ido",
        "ar", "er", "ir",
        "ou", "am", "em",
        "es", "s"
    ]

    for sufixo in sufixos:
        if palavra.endswith(sufixo) and len(palavra) > len(sufixo) + 3:
            return palavra[:-len(sufixo)]

    return palavra


def preprocessar_texto(texto):
    texto = normalizar_texto(texto)
    tokens = tokenizar(texto)
    tokens = remover_stopwords(tokens)
    tokens = [stemming_simples(palavra) for palavra in tokens]

    return " ".join(tokens)


# ============================================================
# 5. APLICAR PRÉ-PROCESSAMENTO
# ============================================================

df["texto_normalizado"] = df["texto"].apply(normalizar_texto)
df["tokens"] = df["texto_normalizado"].apply(tokenizar)
df["tokens_sem_stopwords"] = df["tokens"].apply(remover_stopwords)
df["texto_processado"] = df["texto"].apply(preprocessar_texto)

df["texto_processado"] = df["texto_processado"].fillna("")

