def classificar_publicacao(texto):
    texto_proc = preprocessar_texto(texto)
    texto_vectorizado = tfidf_vectorizer.transform([texto_proc])
    predicao = modelo_interpretavel.predict(texto_vectorizado)[0]

    return predicao


